{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "Freigabeanfrage",
      "size": "Large",
      "weight": "Bolder",
      "color": "Accent"
    },
    {
      "type": "FactSet",
      "facts": [
        { "title": "Dokument:",     "value": "${Dokumentname}" },
        { "title": "Version:",      "value": "${Version}" },
        { "title": "Erstellt von:", "value": "${Ersteller}" },
        { "title": "Prozessart:",   "value": "${Prozessart}" },
        { "title": "Bereich:",      "value": "${Bereich}" },
        { "title": "ISO-Kapitel:",  "value": "${ISOKapitel}" },
        { "title": "Eingereicht:",  "value": "${EingereichtAm}" }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "spacing": "Medium",
      "items": [
        {
          "type": "TextBlock",
          "text": "Änderungen in dieser Version",
          "weight": "Bolder"
        },
        {
          "type": "TextBlock",
          "text": "Art: ${Aenderungsart}",
          "isSubtle": true,
          "spacing": "Small"
        },
        {
          "type": "TextBlock",
          "text": "${Aenderungsbeschreibung}",
          "wrap": true,
          "spacing": "Small"
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Ihr Kommentar (optional):",
      "weight": "Bolder",
      "spacing": "Medium"
    },
    {
      "type": "Input.Text",
      "id": "freigabeKommentar",
      "placeholder": "Optionaler Kommentar zur Entscheidung...",
      "isMultiline": true
    }
  ],
  "actions": [
    {
      "type": "Action.Http",
      "title": "Genehmigen",
      "style": "positive",
      "url": "${ApproveUrl}",
      "body": "{\"decision\":\"approved\",\"comment\":\"${freigabeKommentar}\"}"
    },
    {
      "type": "Action.Http",
      "title": "Ablehnen",
      "style": "destructive",
      "url": "${RejectUrl}",
      "body": "{\"decision\":\"rejected\",\"comment\":\"${freigabeKommentar}\"}"
    },
    {
      "type": "Action.OpenUrl",
      "title": "Dokument öffnen",
      "url": "${DokumentUrl}"
    }
  ]
}
