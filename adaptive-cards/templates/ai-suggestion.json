{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "KI-Verbesserungsvorschlag",
      "size": "Large",
      "weight": "Bolder",
      "color": "Accent"
    },
    {
      "type": "TextBlock",
      "text": "${Vorschlag}",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "Bewertung:",
      "weight": "Bolder"
    },
    {
      "type": "ActionSet",
      "actions": [
        { "type": "Action.Http", "title": "Hilfreich", "url": "${FeedbackUrl}", "body": "{\"rating\":\"helpful\"}" },
        { "type": "Action.Http", "title": "Nicht relevant", "url": "${FeedbackUrl}", "body": "{\"rating\":\"not-relevant\"}" }
      ]
    }
  ],
  "actions": [
    { "type": "Action.OpenUrl", "title": "Dokument öffnen", "url": "${DokumentUrl}" }
  ]
}
