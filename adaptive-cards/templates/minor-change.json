{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "Nebenversion dokumentieren",
      "size": "Large",
      "weight": "Bolder",
      "color": "Default"
    },
    {
      "type": "TextBlock",
      "text": "${Dokumentname}",
      "size": "Medium",
      "weight": "Bolder",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "Nebenversionen benötigen keine Genehmigung. Die Änderung wird direkt im Changelog dokumentiert. Das Dokument bleibt für Leser in der zuletzt freigegebenen Hauptversion sichtbar.",
      "wrap": true,
      "isSubtle": true,
      "spacing": "Small"
    },
    {
      "type": "Container",
      "style": "emphasis",
      "spacing": "Medium",
      "items": [
        {
          "type": "TextBlock",
          "text": "Neue Nebenversionsnummer *",
          "weight": "Bolder"
        },
        {
          "type": "Input.Text",
          "id": "version",
          "placeholder": "z.B. 1.1 / 1.2 / 2.1",
          "value": "${AktuelleVersion}",
          "regex": "^\\d+\\.[1-9]\\d*$",
          "errorMessage": "Nebenversionen enden auf .1, .2 usw. (z.B. 1.1, 2.3)"
        },
        {
          "type": "TextBlock",
          "text": "Art der Änderung *",
          "weight": "Bolder",
          "spacing": "Medium"
        },
        {
          "type": "Input.ChoiceSet",
          "id": "aenderungsart",
          "style": "expanded",
          "isRequired": true,
          "errorMessage": "Bitte Änderungsart auswählen",
          "choices": [
            { "title": "Inhaltliche Änderung",  "value": "Inhaltliche Änderung" },
            { "title": "Formale Korrektur",     "value": "Formale Korrektur" }
          ]
        },
        {
          "type": "TextBlock",
          "text": "Was wurde geändert? *",
          "weight": "Bolder",
          "spacing": "Medium"
        },
        {
          "type": "Input.Text",
          "id": "aenderungsbeschreibung",
          "placeholder": "Kurze Beschreibung der vorgenommenen Änderungen",
          "isMultiline": true,
          "minLength": 10,
          "isRequired": true,
          "errorMessage": "Bitte Änderung beschreiben (mind. 10 Zeichen)"
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "ℹ️ Die Nebenversion ist sofort für Freigeber und den Autor sichtbar. Leser sehen weiterhin die letzte genehmigte Hauptversion.",
      "wrap": true,
      "isSubtle": true,
      "spacing": "Medium",
      "size": "Small"
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Änderung dokumentieren",
      "style": "positive",
      "data": {
        "action": "documentMinorVersion",
        "versionTyp": "Nebenversion",
        "dokumentId": "${DokumentId}",
        "dokumentUrl": "${DokumentUrl}"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Abbrechen",
      "style": "default",
      "data": { "action": "cancel" }
    }
  ]
}
